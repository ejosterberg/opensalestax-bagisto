{
    "name": "ejosterberg/opensalestax-bagisto",
    "description": "Bagisto package — destination-based US sales tax via the self-hosted OpenSalesTax engine",
    "type": "bagisto-package",
    "license": "Apache-2.0",
    "keywords": ["bagisto", "laravel", "tax", "sales-tax", "us-tax", "opensalestax", "tax-calculation"],
    "homepage": "https://github.com/ejosterberg/opensalestax-bagisto",
    "authors": [
        {
            "name": "Eric Osterberg",
            "email": "ejosterberg@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ejosterberg/opensalestax": "^0.1",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/config": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.59",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "OpenSalesTax\\Bagisto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSalesTax\\Bagisto\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OpenSalesTax\\Bagisto\\Providers\\OpenSalesTaxServiceProvider"
            ]
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@stan",
            "@cs",
            "@audit"
        ],
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "audit": "@composer audit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
